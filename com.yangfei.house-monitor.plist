<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.yangfei.house-monitor</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/env</string>
        <string>python3</string>
        <string>/Users/yangfei/WorkBuddy/20260318115523/github-actions-deploy/local_scraper.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/yangfei/WorkBuddy/20260318115523/github-actions-deploy</string>

    <!-- 每天 09:00 运行 -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- 标准输出/错误日志 -->
    <key>StandardOutPath</key>
    <string>/Users/yangfei/WorkBuddy/20260318115523/github-actions-deploy/launchd_stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/yangfei/WorkBuddy/20260318115523/github-actions-deploy/launchd_stderr.log</string>

    <!-- 环境变量 -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
        <key>HOME</key>
        <string>/Users/yangfei</string>
        <key>LANG</key>
        <string>zh_CN.UTF-8</string>
    </dict>

    <!-- 进程退出后不自动重启 -->
    <key>KeepAlive</key>
    <false/>
</dict>
</plist>
